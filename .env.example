# Meta Conversions API (configurar como Supabase Secrets)
# Use: supabase secrets set META_PIXEL_ID=xxx META_ACCESS_TOKEN=xxx META_IG_ACCOUNT_ID=xxx
#
# META_PIXEL_ID          - ID do Pixel/Dataset no Events Manager da Meta
# META_ACCESS_TOKEN      - Token de acesso gerado no Events Manager
# META_IG_ACCOUNT_ID     - ID da conta Instagram Business (default: 17841416335320741)
# META_TEST_EVENT_CODE   - Código de teste (remover em produção) 
#
# Estas variáveis NÃO ficam no frontend. São configuradas como secrets no Supabase.
# Veja: https://supabase.com/docs/guides/functions/secrets

META_PIXEL_ID=seu_pixel_id_aqui
META_ACCESS_TOKEN=seu_access_token_aqui
META_IG_ACCOUNT_ID=17841416335320741
META_TEST_EVENT_CODE=
